# Copy to .env and fill in (never commit .env).
# Atlassian API token: use your account email + token (Basic auth).

BITBUCKET_EMAIL=you@company.com
BITBUCKET_API_TOKEN=

# Workspace slug for api.bitbucket.org/2.0/repositories/{workspace}/...
BITBUCKET_WORKSPACE=

# Optional: repository access token instead of email + API token (Bearer).
# BITBUCKET_TOKEN=
